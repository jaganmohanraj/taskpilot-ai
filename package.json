{
  "name": "taskpilot-ai",
  "version": "0.4.0",
  "description": "Commercial-grade AI-first MCP platform for persistent task execution, anti-drift tracking, verifier-gated completion, and intelligent project management.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postinstall": "tsc -p tsconfig.json",
    "dev": "tsx src/mcp.ts",
    "start": "node dist/server.js",
    "start:mcp": "node dist/mcp.js",
    "start:dashboard": "tsx src/server.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "clean": "rm -rf dist artifacts/*.db",
    "format": "prettier --write 'src/**/*.ts'",
    "lint": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "keywords": [
    "mcp",
    "copilot",
    "task-management",
    "agent",
    "execution",
    "memory",
    "drift-detection",
    "verifier",
    "audit",
    "ai",
    "project-management"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "better-sqlite3": "^11.7.2",
    "express": "^5.2.1",
    "socket.io": "^4.8.3",
    "typescript": "^5.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.test.ts",
      "!src/index.ts",
      "!src/mcp.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
