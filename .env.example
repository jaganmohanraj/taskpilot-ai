# TaskPilot AI Environment Configuration

# Database
# Path to SQLite database file (relative to project root)
DATABASE_PATH=./artifacts/taskpilot.db

# Server Configuration
# Port for dashboard UI (if running standalone)
PORT=3000

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Development
NODE_ENV=development

# MCP Server
# Set to true to enable verbose MCP logging
MCP_DEBUG=false
